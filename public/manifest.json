{
  "manifest_version": 3,
  "name": "Movie Guess Battle",
  "description": "A private-room multiplayer movie guessing battle for Bollywood and Hollywood fans.",
  "version": "0.1.0",
  "action": {
    "default_title": "Movie Guess Battle",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"]
}

